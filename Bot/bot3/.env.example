# Discord bot token for NeetVerse
NEETVERSE_TOKEN=

# OpenRouter is optional for core tracking, required for /ai commands
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# All NeetVerse AI systems enforce OpenRouter's dynamic free-model route
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIMEOUT_SECONDS=60

# Lecture discovery (YouTube Data API v3)
YOUTUBE_API_KEY=
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3
NEETVERSE_OWNER_IDS=

# OpenRouter free accounts commonly have a shared daily cap; keep local limits below it
NEETVERSE_AI_DAILY_GLOBAL_LIMIT=45
NEETVERSE_AI_DAILY_USER_LIMIT=10

# Discord voice replies (Edge TTS + FFmpeg)
NEETVERSE_TTS_DEFAULT_VOICE=en-IN-NeerjaNeural
NEETVERSE_TTS_TIMEOUT_SECONDS=45
NEETVERSE_TTS_MAX_CHARACTERS=1800
NEETVERSE_VOICE_QUEUE_LIMIT=5
NEETVERSE_VOICE_IDLE_SECONDS=300

# Optional comma-separated guild IDs for immediate development command sync
NEETVERSE_GUILD_IDS=
NEETVERSE_DATABASE_PATH=neetverse.sqlite3
NEETVERSE_LOG_LEVEL=INFO
