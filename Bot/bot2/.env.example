# Bot/bot2/.env.example — copy to .env and fill in your values
BOT_TOKEN=your_discord_bot_token_here
LOOKISM_SQLITE_PATH=  # optional, defaults to Bot/bot2/lookism_data.sqlite3
SUPABASE_URL=         # optional, only needed if using Supabase sync
SUPABASE_SERVICE_ROLE_KEY=  # optional, only needed if using Supabase sync
GANG_WAR_PREP_SECONDS=86400
GANG_WAR_BATTLE_SECONDS=86400
