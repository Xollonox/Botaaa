# Hosted deployment environment. Copy these values into your platform's
# environment-variable settings; do not commit a real .env file.

# Bot 1 (required)
DISCORD_TOKEN=
SPECIAL_USER_ID=
CEREBRAS_API_KEY=
CEREBRAS_API_KEY_2=
GROQ_API_KEY=
GROQ_API_KEY_2=
OLLAMA_API_KEY=
OLLAMA_API_KEY_2=
OLLAMA_API_KEY_3=
OLLAMA_API_KEY_4=
OLLAMA_API_KEY_5=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
BLUESMINDS_API_KEY=
MEMORY_FILE=/app/runtime/bot1/bot_memory.json
SETTINGS_FILE=/app/runtime/bot1/bot_settings.json

# Bot 2 (required)
BOT_TOKEN=
LOOKISM_OWNER_IDS=
LOOKISM_DATA_PATH=/app/runtime/bot2/lookism_data.json
LOOKISM_SQLITE_PATH=/app/runtime/bot2/lookism_data.sqlite3
